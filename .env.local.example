# Copy this file to .env.local and fill in your values
# See README.md for where to get each API key

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:1337
NEXT_PUBLIC_SITE_NAME=Nate Builds
NEXT_PUBLIC_VERSION=1.0.0

# Google Analytics
# Get from: https://analytics.google.com (Create a GA4 property)
NEXT_PUBLIC_GA_ID=

# Google reCAPTCHA v3
# Get from: https://www.google.com/recaptcha/admin (Select "reCAPTCHA v3")
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Contact Form Email (Nodemailer + Gmail SMTP)
# App password requires 2-step verification:
# https://myaccount.google.com/apppasswords
# CONTACT_EMAIL_TO must be a real inbox — never an alias that forwards back
# to GMAIL_USER (Gmail dedupes self-sent mail and submissions vanish)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=
CONTACT_EMAIL_TO=your@email.com
# Public From/reply address shown in outgoing mail (default contact@n8builds.dev).
# Gmail only honors it as From if registered as a "Send mail as" alias.
CONTACT_EMAIL_FROM=contact@yourdomain.com

# Sentry (Optional - Error Tracking)
# Get from: https://sentry.io (Free: 5,000 errors/month)
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=