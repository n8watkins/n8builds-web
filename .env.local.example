# Copy this file to .env.local and fill in your values
# See README.md for where to get each API key

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3737
NEXT_PUBLIC_VERSION=1.0.0

# Google Analytics
# Reuse the shared n8builds.dev GA4 property (G-JZQGKY9Q37) — it covers the
# whole domain, including the portfolio.n8builds.dev subdomain. No new property
# needed. Set this to G-JZQGKY9Q37 in .env.local and Vercel.
NEXT_PUBLIC_GA_ID=

# Cloudflare Turnstile
# Create the widget in "Invisible" (or "Managed") mode in the Cloudflare
# Turnstile dashboard. Cloudflare provides always-pass test keys for dev:
#   site key:   1x00000000000000000000AA
#   secret key: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Contact Form Email (Nodemailer + Gmail SMTP)
# App password requires 2-step verification:
# https://myaccount.google.com/apppasswords
# CONTACT_EMAIL_TO must be a real inbox — never an alias that forwards back
# to GMAIL_USER (Gmail dedupes self-sent mail and submissions vanish)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=
CONTACT_EMAIL_TO=your@email.com
# Public From/reply address shown in outgoing mail (default contact@n8builds.dev).
# Gmail only honors it as From if registered as a "Send mail as" alias.
CONTACT_EMAIL_FROM=contact@yourdomain.com

# N8 Notions blog — Sanity dataset (read-only, public CDN)
NEXT_PUBLIC_SANITY_PROJECT_ID="abgyc32w"
