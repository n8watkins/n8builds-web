# ========================================
# ENVIRONMENT CONFIGURATION
# ========================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

NODE_ENV=development

# ========================================
# SITE CONFIGURATION
# ========================================

# Your site URL (used for metadata, redirects, and CORS)
NEXT_PUBLIC_SITE_URL=https://n8builds.dev

# Site name (reserved/unused — the site name is currently hard-coded in app/layout.tsx)
# NEXT_PUBLIC_SITE_NAME=n8builds

# Site version (optional)
NEXT_PUBLIC_VERSION=1.0.0

# ========================================
# GOOGLE ANALYTICS
# ========================================

# Google Analytics Measurement ID (format: G-XXXXXXXXXX)
# Get this from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ========================================
# SANITY (N8 NOTIONS BLOG)
# ========================================

# Sanity project ID for the N8 Notions blog (read-only CDN client).
# REQUIRED: lib/sanity.ts throws at import time if this is unset, so a fresh
# clone crashes on startup without it. (dataset "production" / apiVersion are
# hard-coded in lib/sanity.ts.)
NEXT_PUBLIC_SANITY_PROJECT_ID=abgyc32w

# ========================================
# CLOUDFLARE TURNSTILE
# ========================================
# Create the widget in "Invisible" (or "Managed") mode in the Cloudflare
# Turnstile dashboard: https://dash.cloudflare.com/?to=/:account/turnstile
# Cloudflare provides always-pass test keys for local dev:
#   site key:   1x00000000000000000000AA
#   secret key: 1x0000000000000000000000000000000AA

# Turnstile Site Key (public - exposed to client)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Turnstile Secret Key (private - server-side only)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ========================================
# EMAIL CONFIGURATION (NODEMAILER + GMAIL SMTP)
# ========================================

# Gmail account used to send mail via smtp.gmail.com
GMAIL_USER=your.email@gmail.com

# Gmail app password (NOT your account password)
# Requires 2-step verification; create at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Email address to receive contact form submissions
# Must be a real inbox, NOT a forwarding alias that routes back to GMAIL_USER
# (Gmail dedupes self-sent forwarded mail, so submissions would never appear)
CONTACT_EMAIL_TO=your.email@example.com

# Public From/reply address shown in outgoing mail (default contact@n8builds.dev)
# Gmail SMTP only honors this From if it's registered as a "Send mail as" alias
# on GMAIL_USER (Gmail silently rewrites it otherwise). Receiving replies needs
# a routing rule for this address (e.g. Cloudflare Email Routing → Gmail).
CONTACT_EMAIL_FROM=contact@yourdomain.com

# ========================================
# SOCIAL MEDIA LINKS
# ========================================

# These are used in email templates and footer
LINKEDIN_URL=https://www.linkedin.com/in/yourprofile
GITHUB_URL=https://github.com/yourusername
X_URL=https://x.com/yourusername
CAL_URL=https://cal.com/yourusername/intro

# Optional override for the Appturnity link in email templates
# (defaults to https://appturnity.com if unset)
# APPTURNITY_URL=https://appturnity.com

# ========================================
# SENTRY (error monitoring)
# ========================================

# Sentry IS wired up (@sentry/nextjs + sentry.*.config.ts + instrumentation).
# It stays fully inert until you set NEXT_PUBLIC_SENTRY_DSN — without a DSN the
# SDK is disabled (no network calls). Get the DSN from your Sentry project:
# Settings -> Projects -> <project> -> Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=

# Only needed to UPLOAD SOURCE MAPS so prod stack traces are readable (optional).
# Without these the build still succeeds; you just get minified traces.
# SENTRY_AUTH_TOKEN comes from Sentry: Settings -> Auth Tokens (org-level).
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=n8builds
SENTRY_AUTH_TOKEN=

# ========================================
# SITE DOMAIN (OPTIONAL)
# ========================================

# Your domain without protocol (used in email templates)
SITE_URL=https://n8builds.dev
SITE_DOMAIN=n8builds.dev

# ========================================
# BUILD & DEPLOYMENT
# ========================================

# Set to true to enable bundle analyzer
# Usage: ANALYZE=true npm run build
ANALYZE=false

# CI environment flag (automatically set by most CI providers)
CI=false

# ========================================
# VERCEL (AUTOMATICALLY SET)
# ========================================

# These are automatically set by Vercel, no need to configure:
# VERCEL=1
# VERCEL_ENV=production|preview|development
# VERCEL_URL=your-deployment-url.vercel.app
# NEXT_PUBLIC_VERCEL_URL=your-deployment-url.vercel.app

# ========================================
# NOTES
# ========================================

# Required for production:
# - NEXT_PUBLIC_SITE_URL
# - NEXT_PUBLIC_GA_ID
# - NEXT_PUBLIC_SANITY_PROJECT_ID (lib/sanity.ts throws at import without it)
# - NEXT_PUBLIC_TURNSTILE_SITE_KEY
# - TURNSTILE_SECRET_KEY
# - GMAIL_USER
# - GMAIL_APP_PASSWORD

# Optional (have defaults):
# - CONTACT_EMAIL_TO
# - Social media URLs

# Development only:
# - ANALYZE (for bundle analysis)
