# ========================================
# ENVIRONMENT CONFIGURATION
# ========================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

NODE_ENV=development

# ========================================
# SITE CONFIGURATION
# ========================================

# Your site URL (used for metadata, redirects, and CORS)
NEXT_PUBLIC_SITE_URL=https://n8builds.dev

# Your site name (used in metadata and page titles)
NEXT_PUBLIC_SITE_NAME=Nate Builds

# Site version (optional)
NEXT_PUBLIC_VERSION=1.0.0

# ========================================
# GOOGLE ANALYTICS
# ========================================

# Google Analytics Measurement ID (format: G-XXXXXXXXXX)
# Get this from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ========================================
# RECAPTCHA v3
# ========================================

# reCAPTCHA Site Key (public - exposed to client)
# Get this from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# reCAPTCHA Secret Key (private - server-side only)
# Get this from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# ========================================
# EMAIL CONFIGURATION (NODEMAILER + GMAIL SMTP)
# ========================================

# Gmail account used to send mail via smtp.gmail.com
GMAIL_USER=your.email@gmail.com

# Gmail app password (NOT your account password)
# Requires 2-step verification; create at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Email address to receive contact form submissions
# Must be a real inbox, NOT a forwarding alias that routes back to GMAIL_USER
# (Gmail dedupes self-sent forwarded mail, so submissions would never appear)
CONTACT_EMAIL_TO=your.email@example.com

# Public From/reply address shown in outgoing mail (default contact@n8builds.dev)
# Gmail SMTP only honors this From if it's registered as a "Send mail as" alias
# on GMAIL_USER (Gmail silently rewrites it otherwise). Receiving replies needs
# a routing rule for this address (e.g. Cloudflare Email Routing → Gmail).
CONTACT_EMAIL_FROM=contact@yourdomain.com

# ========================================
# SOCIAL MEDIA LINKS
# ========================================

# These are used in email templates and footer
LINKEDIN_URL=https://www.linkedin.com/in/yourprofile
GITHUB_URL=https://github.com/yourusername
X_URL=https://x.com/yourusername
CAL_URL=https://cal.com/yourusername/intro

# ========================================
# SENTRY ERROR TRACKING
# ========================================

# Sentry DSN (Data Source Name)
# Get this from: https://sentry.io/settings/projects/
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxxx.ingest.sentry.io/xxxxxxx

# Sentry Organization Slug
SENTRY_ORG=your-org-name

# Sentry Project Name
SENTRY_PROJECT=javascript-nextjs

# Sentry Auth Token (for uploading source maps during build)
# Get this from: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# ========================================
# HEALTH CHECK
# ========================================

# Secret token for authenticated health checks (optional)
# Generate a random string: openssl rand -hex 32
HEALTH_CHECK_SECRET=your_random_secret_token_here

# ========================================
# SITE DOMAIN (OPTIONAL)
# ========================================

# Your domain without protocol (used in email templates)
SITE_URL=https://n8builds.dev
SITE_DOMAIN=n8builds.dev

# ========================================
# BUILD & DEPLOYMENT
# ========================================

# Set to true to enable bundle analyzer
# Usage: ANALYZE=true npm run build
ANALYZE=false

# CI environment flag (automatically set by most CI providers)
CI=false

# ========================================
# VERCEL (AUTOMATICALLY SET)
# ========================================

# These are automatically set by Vercel, no need to configure:
# VERCEL=1
# VERCEL_ENV=production|preview|development
# VERCEL_URL=your-deployment-url.vercel.app
# NEXT_PUBLIC_VERCEL_URL=your-deployment-url.vercel.app

# ========================================
# NOTES
# ========================================

# Required for production:
# - NEXT_PUBLIC_SITE_URL
# - NEXT_PUBLIC_GA_ID
# - NEXT_PUBLIC_RECAPTCHA_SITE_KEY
# - RECAPTCHA_SECRET_KEY
# - GMAIL_USER
# - GMAIL_APP_PASSWORD
# - SENTRY_DSN (for error tracking)

# Optional (have defaults):
# - CONTACT_EMAIL_TO
# - Social media URLs
# - HEALTH_CHECK_SECRET

# Development only:
# - ANALYZE (for bundle analysis)
